# Launch profile: Website chat + Twilio WhatsApp
# Recommended if you want live patient messaging next

OPENAI_API_KEY=your_openai_or_openrouter_api_key_here
OPENAI_BASE_URL=
OPENAI_HTTP_REFERER=
OPENAI_APP_NAME=Sabeel Homeo
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Public app settings
PUBLIC_BASE_URL=https://your-public-domain-or-ngrok-url
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase for chat history + knowledge retrieval
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VERIFY_SIGNATURE=true

# Optional voice dependencies, not required for text WhatsApp
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=
DEEPGRAM_API_KEY=

# Unused in this launch profile
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=

WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_NAME=sabeel_homeo
