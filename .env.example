# Sabeel Homeo Clinic AI Chatbot - Environment Variables
# Copy this file to .env and fill in the values for the channels you plan to use.

# OpenAI / OpenRouter
# Leave OPENAI_BASE_URL empty for direct OpenAI usage.
# Set OPENAI_BASE_URL=https://openrouter.ai/api/v1 for OpenRouter.
OPENAI_API_KEY=your_openai_or_openrouter_api_key_here
OPENAI_BASE_URL=
OPENAI_HTTP_REFERER=
OPENAI_APP_NAME="Sabeel Homeo"
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VERIFY_SIGNATURE=true

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Meta / Instagram / Messenger
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here
META_VERIFY_TOKEN=your_custom_verify_token_here

# Public base URL for webhook signature validation and stream/static URL generation
PUBLIC_BASE_URL=https://your-public-domain.com

# Comma-separated CORS origins. Use * only for local/dev.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Evolution API (WhatsApp - Baileys)
# Run with: docker-compose up -d evolution_api
# Then connect via QR code at http://localhost:8080
# For PRODUCTION: set WHATSAPP_WEBHOOK_URL to your public API URL
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sabeel_clinic_key_2024
WHATSAPP_INSTANCE_NAME=sabeel_homeo
WHATSAPP_WEBHOOK_URL=https://your-domain.com/webhook/evolution
