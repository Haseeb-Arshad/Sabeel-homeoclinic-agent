# Launch profile: Full stack
# Website chat + Twilio voice + Twilio WhatsApp + Meta + Evolution
# Use this only if you are actively integrating every channel

OPENAI_API_KEY=your_openai_or_openrouter_api_key_here
OPENAI_BASE_URL=
OPENAI_HTTP_REFERER=
OPENAI_APP_NAME=Sabeel Homeo
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Public app settings
PUBLIC_BASE_URL=https://your-public-domain.com
CORS_ALLOW_ORIGINS=https://your-website.com,http://localhost:3000

# Supabase for chat history + knowledge retrieval
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VERIFY_SIGNATURE=true

# Voice stack
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Meta / Instagram / Messenger
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here
META_VERIFY_TOKEN=your_custom_verify_token_here

# Evolution API (optional alternate WhatsApp provider)
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=your_evolution_api_key_here
WHATSAPP_INSTANCE_NAME=sabeel_homeo
